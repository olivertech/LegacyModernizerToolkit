@model LegacyModernizer.Web.ViewModels.GenerateModernizedClientViewModel

@{
    ViewData["Title"] = "Legacy Modernizer Toolkit";
}

<h1>Legacy Modernizer Toolkit</h1>
<p>Generate a modernized .NET solution from an OpenAPI/Swagger URL.</p>

<form asp-action="Index" method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="GenerationMode" class="form-label"></label>
        <select asp-for="GenerationMode" class="form-select" id="generationMode">
            <option value="Standalone">Standalone</option>
            <option value="Embedded">Embedded</option>
        </select>
        <div class="form-text field-help">
            Define se o Toolkit vai gerar uma solution autônoma para uso isolado ou um módulo incorporável para entrar em uma solution já existente.
        </div>
        <span asp-validation-for="GenerationMode" class="text-danger"></span>
    </div>

    <div class="mb-3" id="embeddedPrefixPanel" style="display:none;">
        <label asp-for="EmbeddedProjectPrefix" class="form-label"></label>
        <input asp-for="EmbeddedProjectPrefix" class="form-control"
               placeholder="AlphaSquad" />
        <div class="form-text">
            Informa o nome base do projeto legado que vai receber os projetos gerados.
            Esse valor é usado para compor nomes como <code>AlphaSquad.Lmt.Application.Contracts</code>.
        </div>
        <div class="form-text">
            Embedded naming preview: <code>{Prefix}.Lmt.Application.Contracts</code>,
            <code>{Prefix}.Lmt.Application.ApiClient</code>,
            <code>{Prefix}.Lmt.Application.Http</code>
        </div>
        <span asp-validation-for="EmbeddedProjectPrefix" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="AuthenticationMode" class="form-label"></label>
        <select asp-for="AuthenticationMode" class="form-select">
            <option value="PerMethodToken">Per Method Token</option>
            <option value="AccessTokenAccessor">Access Token Accessor</option>
        </select>
        <div class="form-text field-help">
            Define se o token será passado explicitamente nos métodos gerados ou resolvido internamente por um <code>IAccessTokenAccessor</code> na aplicação hospedeira.
        </div>
        <span asp-validation-for="AuthenticationMode" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="TargetFramework" class="form-label"></label>
        <select asp-for="TargetFramework" class="form-select">
            <option value="net8.0">.NET 8</option>
            <option value="net9.0">.NET 9</option>
            <option value="net10.0">.NET 10</option>
        </select>
        <div class="form-text field-help">
            Define o framework alvo dos projetos gerados e influencia os arquivos <code>.csproj</code> criados pelo Toolkit.
        </div>
        <span asp-validation-for="TargetFramework" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Specification URL Mode</label>
        <div class="d-flex gap-4">
            <div class="form-check">
                <input class="form-check-input" type="radio"
                       name="UrlMode" id="urlModeProduction" value="production"
                       @(Model.UrlMode == "production" ? "checked" : "") />
                <label class="form-check-label" for="urlModeProduction">
                    Production URL
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio"
                       name="UrlMode" id="urlModeLocalhost" value="localhost"
                       @(Model.UrlMode == "localhost" ? "checked" : "") />
                <label class="form-check-label" for="urlModeLocalhost">
                    Localhost (local API)
                </label>
            </div>
        </div>
        <div class="form-text field-help">
            Escolhe se a specification OpenAPI será lida de uma URL de ambiente publicado ou de uma API local em execução no seu localhost.
        </div>
        <span asp-validation-for="UrlMode" class="text-danger"></span>
    </div>

    <div class="mb-3" id="productionUrlPanel">
        <label asp-for="SpecificationUrl" class="form-label"></label>
        <input asp-for="SpecificationUrl" class="form-control"
               placeholder="https://api.example.com/swagger/v1/swagger.json" />
        <div class="form-text field-help">
            URL pública da specification Swagger/OpenAPI que será usada como contrato de entrada para gerar o client e a solução final.
        </div>
        <span asp-validation-for="SpecificationUrl" class="text-danger"></span>
    </div>

    <div class="mb-3" id="localUrlPanel" style="display:none;">
        <label asp-for="LocalSpecificationUrl" class="form-label"></label>
        <input asp-for="LocalSpecificationUrl" class="form-control"
               placeholder="https://localhost:7054/swagger/v1/swagger.json" />
        <div class="form-text field-help">
            URL local da specification Swagger/OpenAPI, usada quando a API ainda está em desenvolvimento na sua máquina.
        </div>
        <span asp-validation-for="LocalSpecificationUrl" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ProjectName" class="form-label"></label>
        <input asp-for="ProjectName" class="form-control" />
        <div class="form-text field-help">
            Nome lógico da solução gerada. Ele é usado para nomear a solution, a pasta raiz de saída e, no modo standalone, os nomes dos projetos e do pacote ZIP final.
        </div>
        <span asp-validation-for="ProjectName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BaseNamespace" class="form-label"></label>
        <input asp-for="BaseNamespace" class="form-control" />
        <div class="form-text field-help">
            Namespace base usado na geração dos contratos, DTOs e projetos no modo standalone. No modo embedded, ele perde protagonismo porque os namespaces passam a seguir o padrão <code>{Prefix}.Lmt.Application.*</code>.
        </div>
        <span asp-validation-for="BaseNamespace" class="text-danger"></span>
    </div>

    <button id="generateButton" type="submit" class="btn btn-primary">
        <span id="generateButtonText">Generate Solution</span>
        <span id="generateButtonSpinner"
              class="spinner-border spinner-border-sm ms-2 d-none"
              role="status"
              aria-hidden="true"></span>
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const generationModeSelect = document.getElementById('generationMode');
        const embeddedPrefixPanel = document.getElementById('embeddedPrefixPanel');
        const productionPanel = document.getElementById('productionUrlPanel');
        const localPanel = document.getElementById('localUrlPanel');
        const radios = document.querySelectorAll('input[name="UrlMode"]');

        function updateGenerationModePanels() {
            const isEmbedded = generationModeSelect?.value === 'Embedded';
            embeddedPrefixPanel.style.display = isEmbedded ? '' : 'none';
        }

        function updatePanels() {
            const selected = document.querySelector('input[name="UrlMode"]:checked')?.value;
            const isLocal = selected === 'localhost';
            productionPanel.style.display = isLocal ? 'none' : '';
            localPanel.style.display = isLocal ? '' : 'none';
        }

        radios.forEach(r => r.addEventListener('change', updatePanels));
        generationModeSelect?.addEventListener('change', updateGenerationModePanels);
        updateGenerationModePanels();
        updatePanels();

        const form = document.querySelector('form');
        const button = document.getElementById('generateButton');
        const buttonText = document.getElementById('generateButtonText');
        const spinner = document.getElementById('generateButtonSpinner');

        form.addEventListener('submit', function () {
            if (!form.checkValidity()) return;
            button.disabled = true;
            buttonText.textContent = 'Generating...';
            spinner.classList.remove('d-none');
        });
    </script>
}
